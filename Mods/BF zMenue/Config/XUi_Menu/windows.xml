<set xpath="/windows/window[@name='mainMenu']">

		<texture depth="3" color="[white]" texture="@modfolder:UIAtlases/ItemIconAtlas/logox.png" name="gameLogo" anchor_left="#cam,0.5,-20" anchor_bottom="#cam,0.5,20" anchor_right="#cam,0.5,-20" anchor_top="#cam,0.5,490" pivot="center" keep_aspect_ratio="BasedOnHeight" aspect_ratio="2.3" />

		<!-- <texture pos="0,0" height="400" color="[white]" texture="@modfolder:UIAtlases/ItemIconAtlas/logox.png" name="gameLogo" pivot="topleft" keep_aspect_ratio="BasedOnHeight" aspect_ratio="0.608" /> -->

		<grid pos="700,-380" rows="13" cell_width="400" cell_height="80" repeat_content="false" arrangement="vertical" controller="MainMenuButtons">
			<mainmenubutton name="btnPlayGame" width="450" height="55" caption_key="xuiPlayGame" nav_up="{# !is_console ? 'btnQuit' : 'btnNews' }" />
			<mainmenubutton name="btnOptions" width="450" height="55" caption_key="xuiOptions" />
			<mainmenubutton name="btnEditingTools" width="450" height="55" caption_key="xuiEditingTools" platform="!CONSOLE" />
			<mainmenubutton name="btnDlc" width="450" height="55" caption_key="xuiMMDlc" />
			<mainmenubutton name="btnCredits" width="450" height="55" caption_key="xuiCredits" />
			<mainmenubutton name="btnNews" width="450" height="55" caption_key="xuiMMNews" />
			<mainmenubutton name="btnQuit" width="450" height="55" caption_key="xuiQuit" platform="!CONSOLE" />
		</grid>

</set>

<set xpath="/windows/window[@name='menuBackground']">

<texture depth="1" color="[white]" texture="@modfolder:UIAtlases/ItemIconAtlas/background.jpg" name="bgTexture" anchor_left="#cam,0,-5" anchor_bottom="#cam,0,-5" anchor_right="#cam,1,5" anchor_top="#cam,1,5" />

</set>

<!-- Werbung weg -->
<remove xpath="/windows/window[@name='mainMenuNews']"/>

